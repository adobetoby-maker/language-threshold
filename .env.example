# Google Analytics 4 — Measurement ID
# Get from Google Analytics > Admin > Property Settings > Tracking ID
# Format: G-XXXXXXXXXX
VITE_GA_ID=

# Google Ads — Conversion ID
# Get from Google Ads > Goals > Conversions > Tag setup > Format: AW-XXXXXXXXX
VITE_GOOGLE_ADS_ID=

# Meta Pixel — Pixel ID
# Get from Meta Business Manager > Events Manager > Pixels > Format: 15-digit number
VITE_META_PIXEL_ID=
